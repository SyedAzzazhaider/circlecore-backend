# ─────────────────────────────────────────────────────────────────────────────
# CircleCore Backend — Environment Variables Reference
# CC-22 FIX: This file was missing entirely from the project root.
#
# USAGE:
#   cp .env.example .env
#   Fill in all values before starting the server.
#   Never commit your actual .env file — it is in .gitignore.
#
# The server validates required keys at startup via src/config/env.js.
# Missing critical keys cause an immediate startup failure (fail-fast).
# ─────────────────────────────────────────────────────────────────────────────

# ─── Core ─────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
# Comma-separated list of allowed frontend origins (CC-34 CORS allowlist)
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/circlecore

# ─── Redis ────────────────────────────────────────────────────────────────────
# Used for: caching, rate limiting, real-time presence, pub/sub
REDIS_URL=redis://localhost:6379

# ─── JWT Auth ─────────────────────────────────────────────────────────────────
# MINIMUM 32 characters each — validated at startup
JWT_SECRET=change_this_to_a_very_long_random_secret_minimum_32_chars
JWT_REFRESH_SECRET=change_this_to_another_long_random_secret_minimum_32_chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ─── Session ──────────────────────────────────────────────────────────────────
SESSION_TIMEOUT_MINUTES=60

# ─── Email (SendGrid) ─────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# ─── AWS S3 — Media & File Uploads ────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=your_secret_access_key
S3_BUCKET_NAME=your-s3-bucket-name
# Optional: CloudFront CDN URL for serving S3 assets (leave empty if not using CDN)
CLOUDFRONT_URL=

# ─── reCAPTCHA ────────────────────────────────────────────────────────────────
RECAPTCHA_ENABLED=false
RECAPTCHA_SECRET_KEY=your_recaptcha_v2_secret_key
RECAPTCHA_V3_SECRET_KEY=your_recaptcha_v3_secret_key

# ─── Sentry — Error Monitoring (CC-13) ───────────────────────────────────────
# Get your DSN from: https://sentry.io → Your Project → Settings → Client Keys
# Leave empty in local development — Sentry is disabled when SENTRY_DSN is unset
SENTRY_DSN=

# ─── OAuth — Google ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_CALLBACK_URL=https://yourdomain.com/api/auth/oauth/google/callback

# ─── OAuth — LinkedIn ─────────────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_CALLBACK_URL=https://yourdomain.com/api/auth/oauth/linkedin/callback

# ─── OAuth — Apple ────────────────────────────────────────────────────────────
APPLE_CLIENT_ID=your_apple_service_id
APPLE_TEAM_ID=your_apple_team_id
APPLE_KEY_ID=your_apple_key_id
APPLE_PRIVATE_KEY_PATH=./keys/apple_private_key.p8
APPLE_CALLBACK_URL=https://yourdomain.com/api/auth/oauth/apple/callback

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com

# ─── Stripe (see src/env.billing.example for full billing config) ─────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PREMIUM_MONTHLY_PRICE_ID=price_...
STRIPE_PREMIUM_ANNUAL_PRICE_ID=price_...
STRIPE_ENTERPRISE_MONTHLY_PRICE_ID=price_...
STRIPE_ENTERPRISE_ANNUAL_PRICE_ID=price_...

# ─── Razorpay (see src/env.billing.example for full billing config) ───────────
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
RAZORPAY_WEBHOOK_SECRET=...
RAZORPAY_PREMIUM_MONTHLY_PLAN_ID=plan_...
RAZORPAY_PREMIUM_ANNUAL_PLAN_ID=plan_...
RAZORPAY_ENTERPRISE_MONTHLY_PLAN_ID=plan_...
RAZORPAY_ENTERPRISE_ANNUAL_PLAN_ID=plan_...
